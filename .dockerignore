.gitignore

# 编辑器 / IDE
.idea
.vscode
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript 构建信息
*.tsbuildinfo
next-env.d.ts

# 测试覆盖率
coverage
